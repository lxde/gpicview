#: ../data/pref-dlg.ui.h:4
msgid "Show toolbar"
msgstr "ხელსაწყოთა ზოლის ჩვენება"

#: ../data/pref-dlg.ui.h:5
msgid "Ask before saving images"
msgstr "დადასტურება გამოსახულებების შენახვამდე"

#: ../data/pref-dlg.ui.h:6
msgid "Ask before deleting images"
